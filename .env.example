# ─── Runtime ──────────────────────────────────────────────────────────────────
TZ=UTC
PORT=3333
# In Docker / Coolify, HOST must be 0.0.0.0 so the server listens outside the container
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
# Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DO NOT regenerate per deploy — it invalidates issued tokens & cookies
APP_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Two ways to configure — pick one:
#
# (A) Single connection string — recommended for prod (Neon, Supabase, RDS…)
#     DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
#     SSL is auto-enabled when the URL contains sslmode=require.
DATABASE_URL=
#
# (B) Discrete vars — useful for local dev with a vanilla Postgres
#     If DATABASE_URL is set, these are ignored.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=postgres
DB_SSL=false

# ─── Cloudinary (optional, used for cosmetics media) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Discord OAuth ────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match exactly the redirect URI registered in the Discord application
DISCORD_CALLBACK_URL=https://api.beemobot.fr/auth/discord/callback

# ─── Riot API ─────────────────────────────────────────────────────────────────
# Dev keys expire every 24h — request a Production key for prod
RIOT_API_KEY=

# ─── Webapp / CORS ────────────────────────────────────────────────────────────
WEBAPP_URL=https://beemobot.fr
# Comma-separated, no spaces. Include every origin that calls the API.
ALLOWED_ORIGINS=https://beemobot.fr,https://www.beemobot.fr

# ─── Internal service-to-service secret (bot ↔ api) ───────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# ─── Background worker ────────────────────────────────────────────────────────
# Polls Riot match history and enqueues DMs. Enable on exactly one API
# instance (in-process scheduler — running it on multiple replicas would
# cause duplicate Riot calls).
ENABLE_WORKER=true
WORKER_INTERVAL_S=300
